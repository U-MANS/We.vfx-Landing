# EmailJS (https://www.emailjs.com/) — copia a .env (no subas .env al repositorio)
# Clave pública: Account → API Keys
# Template: Email Templates → crear plantilla y copiar el Template ID

VITE_EMAILJS_PUBLIC_KEY=tu_clave_publica
# Opcional si no usas el servicio por defecto del código (service_t358dbv)
# VITE_EMAILJS_SERVICE_ID=service_t358dbv
VITE_EMAILJS_TEMPLATE_ID=tu_template_id
